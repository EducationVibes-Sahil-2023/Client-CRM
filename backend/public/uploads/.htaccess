# Security: never execute code from the uploads directory. Serve files as data
# only. This is defense-in-depth on top of the server-side extension allow-list.
php_flag engine off
AddType text/plain .php .phtml .php3 .php4 .php5 .php7 .phps .pht .phar .cgi .pl .py .sh .asp .aspx .jsp .htm .html

<IfModule mod_rewrite.c>
RewriteEngine Off
</IfModule>

# Apache 2.4+: also strip any handler that might run scripts here.
<IfModule mod_php.c>
php_admin_flag engine off
</IfModule>
