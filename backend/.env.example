#--------------------------------------------------------------------
# CRM Backend Environment — example
# Copy this file to `.env` and fill in your values.
#--------------------------------------------------------------------

CI_ENVIRONMENT = development

app.baseURL = 'http://localhost:8080/'
app.forceGlobalSecureRequests = false
app.indexPage = ''

#--------------------------------------------------------------------
# DATABASE (main shared database)
#--------------------------------------------------------------------
database.default.hostname = localhost
database.default.database = crm_main
database.default.username = root
database.default.password =
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306

#--------------------------------------------------------------------
# SESSION
#--------------------------------------------------------------------
session.driver = 'CodeIgniter\Session\Handlers\FileHandler'
session.cookieName = 'crm_session'
session.expiration = 7200

#--------------------------------------------------------------------
# CRM
#--------------------------------------------------------------------
crm.clientDbPrefix = client_

#--------------------------------------------------------------------
# GMAIL INBOX (IMAP, App Password)
#--------------------------------------------------------------------
# The admin Inbox reads this Gmail account over IMAP. Use a Google
# "App Password" (Account → Security → 2-Step Verification → App passwords),
# NOT your normal login password. Spaces in the app password are ignored.
gmail.user = ''
gmail.appPassword = ''
gmail.mailbox = '{imap.gmail.com:993/imap/ssl}INBOX'
