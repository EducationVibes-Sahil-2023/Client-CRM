#--------------------------------------------------------------------
# CRM Backend — PRODUCTION environment template
#
# Copy this to `.env` ON THE SERVER and fill in the real values. Never
# commit the real `.env`. Topology: one domain, the API reverse-proxied
# under /api (https://client.educationvibes.in/api) → so cookies are
# first-party and CORS is not needed.
#--------------------------------------------------------------------

CI_ENVIRONMENT = production

# Public base of the API. Because nginx proxies /api/ → this app's root,
# the API is reachable at https://<domain>/api/.
app.baseURL = 'https://client.educationvibes.in/api/'
app.indexPage = ''

# Leave FALSE: TLS is terminated by nginx, which also does the 80→443
# redirect. Turning this on while behind a proxy can cause redirect loops.
app.forceGlobalSecureRequests = false

#--------------------------------------------------------------------
# SECURE COOKIES (drives BOTH the session cookie and CSRF cookie)
# These .env keys override Config\Cookie — no PHP edits needed.
#   secure   = true  → cookie only sent over HTTPS (required in prod)
#   samesite = Lax   → safe & sufficient because frontend+API share the
#                      domain (first-party). Do NOT use None here.
#   domain   = ''    → host-only cookie for the exact domain (correct for
#                      a single-domain deploy).
#--------------------------------------------------------------------
cookie.secure   = true
cookie.samesite = 'Lax'
cookie.domain   = ''

#--------------------------------------------------------------------
# DATABASE (main shared database) — use the production MySQL credentials.
# Per-client tenant databases are created/upgraded by `php spark db:upgrade`.
#--------------------------------------------------------------------
database.default.hostname = localhost
database.default.database = crm_main
database.default.username = CHANGE_ME
database.default.password = CHANGE_ME
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306

#--------------------------------------------------------------------
# SESSION — FileHandler is fine for a single server. If you ever run more
# than one backend node, switch to the database/redis handler so sessions
# are shared.
#--------------------------------------------------------------------
session.driver = 'CodeIgniter\Session\Handlers\FileHandler'
session.cookieName = 'crm_session'
session.expiration = 7200

#--------------------------------------------------------------------
# CRM
#--------------------------------------------------------------------
crm.clientDbPrefix = client_

#--------------------------------------------------------------------
# GMAIL INBOX (IMAP, App Password) — optional
#--------------------------------------------------------------------
gmail.user = ''
gmail.appPassword = ''
gmail.mailbox = '{imap.gmail.com:993/imap/ssl}INBOX'

#--------------------------------------------------------------------
# WEB PUSH (VAPID) — generate once with `php spark push:keys` and reuse
# the SAME keypair in every environment (browsers tie subscriptions to it).
#--------------------------------------------------------------------
vapid.subject    = 'mailto:admin@educationvibes.in'
vapid.publicKey  = CHANGE_ME
vapid.privateKey = CHANGE_ME
